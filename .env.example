# Frontend configuration
VITE_API_BASE_URL=http://127.0.0.1:8000

# LLM & Embeddings API
GEMINI_API_KEY=your_gemini_api_key_here

# Security configuration (Guardrails)
MAX_QUERY_LENGTH=2000
MAX_CONTEXT_LENGTH=12000
MAX_OUTPUT_TOKENS=800
MAX_RETRIEVED_CHUNKS=8
RATE_LIMIT=30
RATE_WINDOW_SECONDS=60
SIMILARITY_THRESHOLD=0.12
HALLUCINATION_THRESHOLD=0.45
PROMPT_INJECTION_THRESHOLD=0.65
ALLOWED_FILE_TYPES=txt,md,pdf,docx

# RAG Pipeline Configuration
RAG_LLM_PROVIDER=gemini
RAG_LLM_MODEL=gemini-2.5-flash
RAG_EMBEDDING_MODEL=text-embedding-004
RAG_CHUNK_STRATEGY=recursive
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_RETRIEVAL_TOP_K=20
RAG_RETRIEVER_TYPE=hybrid
RAG_RERANKING_ENABLED=true
RAG_AGENT_ENABLED=true
RAG_HYDE_ENABLED=false
RAG_MEMORY_ENABLED=true
VECTOR_DB_PATH=data/chroma_db
